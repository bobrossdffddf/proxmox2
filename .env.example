# ============================================================================
# WCTARange environment configuration
# Copy this to .env and fill in your own values. .env is gitignored.
# ============================================================================

# ---- Public URLs ----
# These are how students reach the app. If you're running on the local network
# you can keep these as-is and change them later when you put it behind HTTPS.
PUBLIC_URL=http://localhost:8080

# ---- Auth ----
# JWT signing secret. Generate one with: openssl rand -hex 64
JWT_SECRET=change-me-to-a-long-random-string-at-least-64-chars
JWT_EXPIRES_IN=12h

# ---- Database ----
POSTGRES_USER=wcta
POSTGRES_PASSWORD=change-me-too
POSTGRES_DB=wctarange

# ---- Redis ----
# No password by default. Redis is only reachable on the internal docker network.
REDIS_URL=redis://redis:6379

# ---- Proxmox ----
# Create a token in: Datacenter -> Permissions -> API Tokens
# Required permissions: VM.Allocate, VM.Audit, VM.Clone, VM.Config.Disk,
# VM.Config.HWType, VM.Config.Memory, VM.Config.Network, VM.Config.Options,
# VM.Migrate, VM.Monitor, VM.PowerMgmt, VM.Snapshot, VM.Snapshot.Rollback
# Privilege separation: NO (the token needs the same perms as its user)
PROXMOX_TOKEN_ID=wctarange@pve!provisioner
PROXMOX_TOKEN_SECRET=paste-the-uuid-secret-here
# If your Proxmox certs are self-signed (default), keep this false.
PROXMOX_VERIFY_TLS=false

# ---- guacd (RDP/VNC protocol translator) ----
# Internal hostname inside the docker network. Don't change unless you know why.
GUACD_HOST=guacd
GUACD_PORT=4822

# ---- Quotas and timeouts ----
MAX_VMS_PER_USER=2
MAX_CLUSTER_VMS=60
SESSION_HARD_TIMEOUT_MINUTES=240
SESSION_INACTIVITY_TIMEOUT_MINUTES=30
HEARTBEAT_INTERVAL_SECONDS=10

# ---- VM ID pool ----
# Cloned VMs get IDs in this range. Make sure it doesn't collide with your
# template IDs or any production VMs you have on the cluster.
VM_ID_RANGE_START=10000
VM_ID_RANGE_END=19999

# ---- Backend server ----
NODE_ENV=production
LOG_LEVEL=info
BACKEND_PORT=3000

# ---- Frontend (nginx) ----
FRONTEND_PORT=8080
